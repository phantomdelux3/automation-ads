# ──────────────────────────────────────────────
# Keywords & Targeting
# ──────────────────────────────────────────────
# Comma-separated list of keywords to search on Google
KEYWORDS=shein coupon code,shein promo code,shein coupon,shein discount
# Comma-separated list of target domains — ads matching these get clicked
TARGET_DOMAINS=couponfollow.com,discoup.com
# Set to false to also click organic (non-ad) results matching target domains
SPONSORED_ONLY=false
# How many sessions to run per keyword
SESSIONS_PER_KEYWORD=1

# ──────────────────────────────────────────────
# Cookie Warmup (visit Google properties before searching)
# ──────────────────────────────────────────────
# Set to false to skip Google cookie warmup (YouTube, Google News)
COOKIE_WARMUP=false

# ──────────────────────────────────────────────
# Site Browsing (after clicking the ad)
# ──────────────────────────────────────────────
# Min/max seconds to browse the landing page
SITE_BROWSE_MIN=15
SITE_BROWSE_MAX=45
# Min/max internal pages to visit on the target site
INTERNAL_PAGES_MIN=1
INTERNAL_PAGES_MAX=3

# ──────────────────────────────────────────────
# Timing (milliseconds)
# ──────────────────────────────────────────────
MIN_DELAY=3000
MAX_DELAY=10000
MIN_SCROLL_DELAY=500
MAX_SCROLL_DELAY=2000

# ──────────────────────────────────────────────
# Browser
# ──────────────────────────────────────────────
HEADLESS=false
LOGIN_EMAIL=true

# Search History — build browsing profile before searching
SEARCH_HISTORY=false
SEARCH_HISTORY_COUNT=3

# Custom warmup URLs (comma-separated, optional)
# WARMUP_URLS=https://www.retailmenot.com/,https://www.coupons.com/

# ──────────────────────────────────────────────
# Proxy (optional)
# ──────────────────────────────────────────────

# PROXY_LIST=us.decodo.com:10001,us.decodo.com:10002,us.decodo.com:10003,us.decodo.com:10004,us.decodo.com:10005,us.decodo.com:10006,us.decodo.com:10007,us.decodo.com:10008,us.decodo.com:10009,us.decodo.com:10010,us.decodo.com:10011,us.decodo.com:10012,us.decodo.com:10013,us.decodo.com:10014,us.decodo.com:10015,us.decodo.com:10016,us.decodo.com:10017,us.decodo.com:10018,us.decodo.com:10019,us.decodo.com:10020,us.decodo.com:10021,us.decodo.com:10022,us.decodo.com:10023,us.decodo.com:10024,us.decodo.com:10025,us.decodo.com:10026,us.decodo.com:10027,us.decodo.com:10028,us.decodo.com:10029,us.decodo.com:10030
# PROXY_USER=
# PROXY_PASS=

# ──────────────────────────────────────────────
# Bright Data SERP API
# ──────────────────────────────────────────────
# Use SERP API for Google Searches to bypass KYC requirements on proxy
# USE_SERP_API=true
# BRIGHTDATA_SERP_API_KEY=

# ──────────────────────────────────────────────
# 2Captcha (automatic reCAPTCHA solving)
# ──────────────────────────────────────────────
# API key from 2captcha.com — used to auto-solve reCAPTCHA v2
# when Google's "unusual traffic" page appears
2CAPTCHA_API_KEY=

# ──────────────────────────────────────────────
# Loop Configuration
# ──────────────────────────────────────────────
# Set to 'true' to loop the task infinitely.
LOOP_BOT=false
# ----------------------------------------------
# Proxy / Diagnostic
# ----------------------------------------------
# Shows the actual evaluated proxy IP address on every session launch.
SHOW_PROXY_IP=true