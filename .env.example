# Target Configuration
TARGET_URL=https://www.savingsatlas.com/stores/1800contacts.com
AD_SELECTOR=.ad-banner
CLICK_COUNT=3

# Timing (milliseconds)
MIN_DELAY=3000
MAX_DELAY=10000
MIN_SCROLL_DELAY=500
MAX_SCROLL_DELAY=2000

# Browser
HEADLESS=false

# Search History — build browsing profile before targeting
# Set to false to skip, true (default) to enable
SEARCH_HISTORY=true
SEARCH_HISTORY_COUNT=3

# Custom search queries (comma-separated, optional — defaults built in)
# SEARCH_QUERIES=best coupon codes,online shopping deals,cashback offers

# Custom warmup URLs (comma-separated, optional — defaults built in)
# WARMUP_URLS=https://www.retailmenot.com/,https://www.coupons.com/

# Proxy (add later)
# PROXY_LIST=proxy1:port,proxy2:port,proxy3:port
# PROXY_USER=
# PROXY_PASS=
