        }
        @media (max-width: 480px) {
          .blog-cat-tab {
            padding: 12px 18px;
            min-width: 100px;
            border-radius: 12px;
          }
        }
        .blog-cat-tab:hover {
          background: #fff;
          box-shadow: 0 4px 16px rgba(97,169,159,0.13);
          border-color: var(--prim-exlight);
        }
        .blog-cat-tab.active {
          background: #fff;
          border-color: var(--prim);
          box-shadow: 0 4px 20px rgba(97,169,159,0.18);
        }
        .blog-cat-tab i {
          font-size: 26px;
          color: #9ca3af;
          transition: color 0.25s;
        }
        .blog-cat-tab.active i {
          color: var(--prim);
        }
        .blog-cat-tab:hover i {
          color: var(--prim);
        }
        .blog-cat-tab .cat-label {
          font-size: 14px;
          font-weight: 600;
          color: #374151;
          font-family: 'Inter', sans-serif;
        }
        .blog-cat-tab.active .cat-label {
          color: var(--prim-dark);
        }
        .blog-cat-tab .cat-count {
          font-size: 11px;
          font-weight: 600;
          background: #e8f5f3;
          color: var(--prim-dark);
          padding: 2px 10px;
          border-radius: 20px;
        }
        .blog-cat-tab.active .cat-count {
          background: var(--prim);
          color: #fff;
        }

        /* ===== EXPLORE CARDS GRID ===== */
        .blog-explore-wrap {
          background: linear-gradient(135deg, #e8f5f3 0%, #f0fdf9 100%);
          border-radius: 20px;
          padding: 28px 24px;
          margin-top: 12px;
        }
        @media (max-width: 768px) {
          .blog-explore-wrap {
            padding: 20px 14px;
            border-radius: 16px;
          }
        }
        .blog-explore-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 20px;
        }
        @media (max-width: 1024px) {
          .blog-explore-grid {
            grid-template-columns: repeat(2, 1fr);
          }
        }
        @media (max-width: 640px) {
          .blog-explore-grid {
            grid-template-columns: 1fr;
            gap: 14px;
          }
        }

        /* ===== EXPLORE CARD ===== */
        .blog-explore-card {
          background: #fff;
          border-radius: 14px;
          overflow: hidden;
          border: 1px solid #e5eeec;
          transition: all 0.3s ease;
          display: flex;
          flex-direction: column;
        }
        .blog-explore-card:hover {
          box-shadow: 0 8px 28px rgba(97,169,159,0.15);
          transform: translateY(-3px);
          border-color: var(--prim-exlight);
        }
        .blog-explore-card-img {
          width: 100%;
          height: 160px;
          object-fit: cover;
          display: block;
        }
        @media (max-width: 640px) {
          .blog-explore-card-img {
            height: 140px;
          }
        }
        .blog-explore-card-body {
          padding: 14px 16px 16px;
          display: flex;
          flex-direction: column;
          flex: 1;
        }
        .blog-explore-card-tag {
          display: inline-block;
          font-size: 11px;
          font-weight: 600;
          font-family: 'Inter', sans-serif;
          background: #e8f5f3;
          color: var(--prim-dark);
          padding: 3px 10px;
          border-radius: 20px;
          margin-bottom: 8px;
          width: fit-content;
        }
        .blog-explore-card h3 {
          font-family: 'Lora', serif;
          font-weight: 700;
          font-size: 15px;
          line-height: 1.35;
          color: #1f2937;
          margin-bottom: 6px;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
        .blog-explore-card-desc {
          font-size: 13px;
          line-height: 1.45;
          color: #6b7280;
          margin-bottom: 10px;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
          flex: 1;
        }
        .blog-explore-card-footer {
          display: flex;
          align-items: center;
          justify-content: space-between;
          margin-top: auto;
        }
        .blog-explore-card-date {
          font-size: 12px;
          color: #9ca3af;
          font-family: 'Inter', sans-serif;
        }
        .blog-explore-card-link {
          font-size: 13px;
          font-weight: 600;
          color: var(--prim);
          display: flex;
          align-items: center;
          gap: 4px;
          text-decoration: none !important;
          transition: color 0.2s, gap 0.2s;
        }
        .blog-explore-card-link:hover {
          color: var(--prim-dark) !important;
          text-decoration: none !important;
          gap: 7px;
        }

        /* ===== BRANDS STRIP (TEAL) ===== */
        .blog-brands-strip {
          background: linear-gradient(135deg, var(--prim) 0%, var(--prim-dark) 100%);
          padding: 28px 0;
          margin-top: 40px;
        }
        @media (max-width: 768px) {
          .blog-brands-strip {
            padding: 20px 0;
            margin-top: 28px;
          }
        }
        .blog-brands-strip-title {
          color: #fff;
          font-weight: 600;
          font-size: 15px;
          text-align: center;
          margin-bottom: 16px;
          font-family: 'Inter', sans-serif;
        }
        .blog-brands-strip-row {
          display: flex;
          flex-wrap: wrap;
          justify-content: center;
          align-items: center;
          gap: 28px;
          padding: 0 20px;
        }
        @media (max-width: 640px) {
          .blog-brands-strip-row {
            gap: 16px;
          }
        }
        .blog-brands-strip-item {
          display: block;
          background: rgba(255,255,255,0.15);
          border-radius: 12px;
          padding: 8px 14px;
          transition: all 0.25s;
        }
        .blog-brands-strip-item:hover {
          background: rgba(255,255,255,0.3);
          transform: scale(1.06);
          text-decoration: none;
        }
        .blog-brands-strip-item img {
          height: 32px;
          width: auto;
          object-fit: contain;
          filter: brightness(0) invert(1);
        }

        /* ===== TOP BLOG POSTS (TEAL THEME) ===== */
        .blog-top-section {
          max-width: 1280px;
          margin: 0 auto;
          padding: 40px 16px 20px;
        }
        @media (max-width: 768px) {
          .blog-top-section {
            padding: 28px 12px 12px;
          }
        }
        .blog-top-heading {
          font-family: 'Lora', serif;
          font-weight: 700;
          font-size: 30px;
          margin-bottom: 28px;
        }
        @media (max-width: 768px) {
          .blog-top-heading {
            font-size: 24px;
            margin-bottom: 20px;
          }
        }

        /* Category header bar — TEAL instead of red */
        .blog-top-cat-header {
          display: flex;
          align-items: center;
          background: linear-gradient(135deg, var(--prim) 0%, var(--prim-exdark) 100%);
          border-radius: 14px;
          padding: 0 24px;
          height: 64px;
          margin-bottom: 0;
        }
        @media (max-width: 768px) {
          .blog-top-cat-header {
            padding: 12px 16px;
            height: auto;
            border-radius: 12px;
          }
        }
        .blog-top-cat-number {
          display: flex;
          justify-content: center;
          align-items: center;
          width: 40px;
          height: 40px;
          background: #fff;
          color: var(--prim);
          font-family: 'Lora', serif;
          font-weight: 700;
          font-size: 20px;
          border-radius: 50%;
          margin-right: 14px;
          flex-shrink: 0;
        }
        .blog-top-cat-name {
          font-family: 'Lora', serif;
          font-weight: 700;
          font-size: 22px;
          color: #fff;
        }
        @media (max-width: 768px) {
          .blog-top-cat-name {
            font-size: 17px;
          }
        }

        /* Main featured blog card */
        .blog-top-featured {
          display: flex;
          flex-direction: row;
          gap: 24px;
          padding: 24px;
          border: 1px solid #e5eeec;
          border-top: none;
          border-radius: 0 0 14px 14px;
          background: #fff;
          position: relative;
        }
        @media (max-width: 768px) {
          .blog-top-featured {
            flex-direction: column;
            padding: 16px;
            gap: 14px;
          }
        }
        .blog-top-featured-img {
          width: 420px;
          height: 240px;
          object-fit: cover;
          border-radius: 10px;
          flex-shrink: 0;
        }
        @media (max-width: 1024px) {
          .blog-top-featured-img {
            width: 300px;
            height: 180px;
          }
        }
        @media (max-width: 768px) {
          .blog-top-featured-img {
            width: 100%;
            height: 180px;
          }
        }
        .blog-top-featured-info {
          display: flex;
          flex-direction: column;
          justify-content: center;
          flex: 1;
          min-width: 0;
        }
        .blog-top-featured-info h3 {
          font-family: 'Lora', serif;
          font-weight: 700;
          font-size: 22px;
          line-height: 1.3;
          color: #1f2937;
          margin-bottom: 8px;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
        @media (max-width: 768px) {
          .blog-top-featured-info h3 {
            font-size: 18px;
          }
        }
        .blog-top-featured-desc {
          font-size: 14px;
          color: #6b7280;
          line-height: 1.5;
          margin-bottom: 12px;
          display: -webkit-box;
          -webkit-line-clamp: 3;
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
        @media (max-width: 768px) {
          .blog-top-featured-desc {
            -webkit-line-clamp: 2;
            font-size: 13px;
          }
        }
        .blog-top-featured-date {
          font-size: 13px;
          color: #9ca3af;
          font-family: 'Inter', sans-serif;
          margin-bottom: 16px;
        }
        @media (max-width: 768px) {
          .blog-top-featured-date {
            margin-bottom: 10px;
          }
        }

        /* Know More button — TEAL */
        .blog-top-know-more {
          display: inline-flex;
          align-items: center;
          gap: 6px;
          background: linear-gradient(135deg, var(--prim) 0%, var(--prim-dark) 100%);
          color: #fff !important;
          text-decoration: none !important;
          font-family: 'Inter', sans-serif;
          font-weight: 600;
          font-size: 14px;
          padding: 10px 24px;
          border-radius: 10px;
          transition: all 0.25s;
          width: fit-content;
          z-index: 2;
        }
        .blog-top-know-more:hover {
          background: linear-gradient(135deg, var(--prim-dark) 0%, var(--prim-exdark) 100%);
          text-decoration: none !important;
          color: #fff !important;
          box-shadow: 0 4px 14px rgba(97,169,159,0.3);
        }
        @media (max-width: 768px) {
          .blog-top-know-more {
            width: 100%;
            justify-content: center;
            padding: 10px 20px;
          }
        }

        /* Related blogs slider */
        .blog-top-related-row {
          display: flex;
          overflow-x: auto;
          gap: 16px;
          padding: 16px 24px 20px;
          border: 1px solid #e5eeec;
          border-top: none;
          border-radius: 0 0 14px 14px;
          background: #fafffe;
          scrollbar-width: none;
          -ms-overflow-style: none;
        }
        .blog-top-related-row::-webkit-scrollbar {
          display: none;
        }
        @media (max-width: 768px) {
          .blog-top-related-row {
            padding: 12px 14px 16px;
          }
        }
        .blog-top-related-card {
          display: flex;
          gap: 12px;
          align-items: center;
          min-width: 280px;
          flex-shrink: 0;
          padding-right: 16px;
          border-right: 1px solid #e5eeec;
          text-decoration: none !important;
        }
        .blog-top-related-card:last-child {
          border-right: none;
          padding-right: 0;
        }
        .blog-top-related-card:hover h4 {
          text-decoration: underline;
        }
        .blog-top-related-card img {
          width: 100px;
          height: 72px;
          object-fit: cover;
          border-radius: 8px;
          flex-shrink: 0;
        }
        .blog-top-related-card h4 {
          font-family: 'Lora', serif;
          font-weight: 700;
          font-size: 14px;
          line-height: 1.35;
          color: #1f2937;
          display: -webkit-box;
          -webkit-line-clamp: 2;
          -webkit-box-orient: vertical;
          overflow: hidden;
          margin-bottom: 4px;
        }
        .blog-top-related-meta {
          font-size: 12px;
          color: #9ca3af;
          font-family: 'Inter', sans-serif;
        }

        /* Category group wrapper */
        .blog-top-cat-group {
          margin-bottom: 32px;
          border-radius: 14px;
          overflow: hidden;
        }
        @media (max-width: 768px) {
          .blog-top-cat-group {
            margin-bottom: 24px;
          }
        }

        /* Skeleton loaders */
        .blog-skel {
          background: linear-gradient(90deg, #e8f0ef 25%, #f0f8f7 50%, #e8f0ef 75%);
          background-size: 200% 100%;
          animation: blog-skel-shine 1.5s ease infinite;
          border-radius: 12px;
        }
        @keyframes blog-skel-shine {
          0% { background-position: 200% 0; }
          100% { background-position: -200% 0; }
        }

        /* Empty state */
        .blog-empty {
          text-align: center;
          color: #9ca3af;
          padding: 40px 20px;
          font-size: 15px;
          font-family: 'Inter', sans-serif;
        }

        /* View More button */
        .blog-view-more-wrap {
          display: flex;
          justify-content: center;
          margin-top: 20px;
        }
        .blog-view-more-btn {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          padding: 10px 28px;
          border: 2px solid var(--prim);
          color: var(--prim-dark);
          background: #fff;
          border-radius: 12px;
          font-family: 'Inter', sans-serif;
          font-weight: 600;
          font-size: 14px;
          cursor: pointer;
          transition: all 0.25s;
        }
        .blog-view-more-btn:hover {
          background: var(--prim);
          color: #fff;
          box-shadow: 0 4px 14px rgba(97,169,159,0.25);
        }
        .blog-view-more-btn svg {
          transition: transform 0.25s;
        }
        .blog-view-more-btn:hover svg {
          transform: translateY(2px);
        }

        /* ===== BRANDS MARQUEE ===== */
        .blog-brands-marquee-section {
          background: linear-gradient(135deg, var(--prim) 0%, var(--prim-dark) 100%);
          padding: 28px 0;
          margin-top: 40px;
          overflow: hidden;
        }
        @media (max-width: 768px) {
          .blog-brands-marquee-section {
            padding: 20px 0;
            margin-top: 28px;
          }
        }
        .blog-brands-marquee-title {
          color: #fff;
          font-weight: 600;
          font-size: 15px;
          text-align: center;
          margin-bottom: 20px;
          font-family: 'Inter', sans-serif;
          letter-spacing: 0.3px;
        }
        .blog-marquee-outer {
          position: relative;
          overflow: hidden;
          width: 100%;
          -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
          mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
        }
        .blog-marquee-track {
          display: flex;
          align-items: center;
          width: max-content;
          animation: marquee-scroll 40s linear infinite;
        }
        .blog-marquee-track:hover {
          animation-play-state: paused;
        }
        @keyframes marquee-scroll {
          0% { transform: translateX(0); }
          100% { transform: translateX(-25%); }
        }
        .blog-marquee-item {
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 10px 40px;
          flex-shrink: 0;
          opacity: 0.85;
          transition: opacity 0.3s, transform 0.3s;
          color: rgba(255,255,255,0.92);
          height: 48px;
        }
        .blog-marquee-item:hover {
          opacity: 1;
          transform: scale(1.08);
        }
        .blog-marquee-item svg {
          height: 30px;
          width: auto;
          display: block;
        }
        @media (max-width: 640px) {
          .blog-marquee-item {
            padding: 8px 24px;
            height: 40px;
          }
          .blog-marquee-item svg {
            height: 22px;
          }
        }
        .blog-marquee-divider {
          width: 1px;
          height: 24px;
          background: rgba(255,255,255,0.22);
          flex-shrink: 0;
          align-self: center;
        }
